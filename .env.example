# AI consultation widget (server-side only — never exposed to the browser)
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Sanity.io (blog CMS). Leave empty to use the built-in placeholder posts.
# See sanity/README.md for setup instructions. Studio is embedded at /studio.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# Write-scoped Sanity token, only needed to run `npm run seed` once
# (manage.sanity.io → project → API → Tokens → Editor). Not used at runtime,
# don't set this in Vercel.
SANITY_API_WRITE_TOKEN=

# Contact form submission endpoint (e.g. https://formspree.io/f/your-id).
# Leave empty and the form will render with a notice instead of submitting.
NEXT_PUBLIC_FORM_ENDPOINT=

# Newsletter signup endpoint — a separate Formspree form (or Mailchimp/
# ConvertKit form action URL) so subscribers land in their own list, not
# mixed with contact-form inquiries. Leave empty to show a "not configured"
# notice instead of the working form.
NEXT_PUBLIC_NEWSLETTER_ENDPOINT=

# Canonical site URL — used for sitemap.xml, robots.txt, canonical/hreflang
# tags and JSON-LD. Set this once a custom domain is attached; falls back to
# the Vercel-assigned URL otherwise.
NEXT_PUBLIC_SITE_URL=
